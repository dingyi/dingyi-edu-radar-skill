<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  dingyi-edu-radar 每周自动刷新定时任务模板。
  使用前：把下方的 <HOME> 替换为你的用户主目录（如 /Users/yourname），
  然后复制到 ~/Library/LaunchAgents/ 并执行：
    launchctl load ~/Library/LaunchAgents/cn.bao.edumails-radar-refresh.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>cn.bao.edumails-radar-refresh</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string><HOME>/.agents/skills/dingyi-edu-radar/scripts/refresh.sh</string>
    </array>

    <!-- 每周一 03:00 触发 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>1</integer>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string><HOME>/.agents/skills/dingyi-edu-radar/scripts/refresh.log</string>
    <key>StandardErrorPath</key>
    <string><HOME>/.agents/skills/dingyi-edu-radar/scripts/refresh.log</string>

    <!-- 环境变量：按你的 python3 + bs4 实际路径调整 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
